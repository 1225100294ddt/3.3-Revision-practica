<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<HBox alignment="CENTER" spacing="40" style="-fx-background-color: #70787C; -fx-padding: 50;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml">
    
    <VBox style="-fx-background-color: #D6D7D7; -fx-border-color: #C0C1C1; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;" prefWidth="300" prefHeight="200">
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #C9CACB; -fx-padding: 10; -fx-background-radius: 10 10 0 0;">
            <Label text="Light Mode" style="-fx-text-fill: #4F5051; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Circle radius="8" fill="#9A9B9C"/>
        </HBox>
        <VBox spacing="15" style="-fx-padding: 20;">
            <Rectangle width="150" height="15" arcWidth="10" arcHeight="10" fill="#9A9B9C"/>
            <GridPane hgap="10" vgap="10">
                <Circle radius="10" fill="#9A9B9C" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Circle radius="10" fill="#9A9B9C" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Circle radius="10" fill="#9A9B9C" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <Circle radius="10" fill="#9A9B9C" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Circle radius="10" fill="#9A9B9C" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Circle radius="10" fill="#9A9B9C" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            </GridPane>
        </VBox>
    </VBox>

    <VBox style="-fx-background-color: #1E1E1E; -fx-border-color: #2A2A2A; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;" prefWidth="300" prefHeight="200">
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-background-radius: 10 10 0 0;">
            <Label text="Dark Mode" style="-fx-text-fill: #A0A1A1; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Circle radius="8" fill="#6F7070"/>
        </HBox>
        <VBox spacing="15" style="-fx-padding: 20;">
            <Rectangle width="150" height="15" arcWidth="10" arcHeight="10" fill="#333333"/>
            <GridPane hgap="10" vgap="10">
                <Circle radius="10" fill="#333333" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Circle radius="10" fill="#333333" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Circle radius="10" fill="#333333" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <Circle radius="10" fill="#333333" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Circle radius="10" fill="#333333" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Circle radius="10" fill="#333333" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            </GridPane>
        </VBox>
    </VBox>
    
</HBox>