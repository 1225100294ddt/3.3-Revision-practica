<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/10.0.2-internal" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="CENTER_LEFT" prefWidth="400.0" spacing="20" style="-fx-padding: 50; -fx-background-color: #f4f4f4;">
        <Label text="Speak your" style="-fx-font-size: 28px;"/>
        <Label text="Email and password" style="-fx-font-size: 18px; -fx-text-fill: #555;"/>
        <TextField promptText="Email" style="-fx-pref-height: 40;"/>
        <PasswordField promptText="Password" style="-fx-pref-height: 40;"/>
        <Button text="Login" style="-fx-background-color: #ff8c00; -fx-text-fill: white; -fx-pref-width: 100; -fx-pref-height: 40;"/>
    </VBox>
    
    <VBox alignment="CENTER" prefWidth="400.0" spacing="15" style="-fx-padding: 40; -fx-background-color: #ff8c00;">
        <Label text="Register" style="-fx-text-fill: white; -fx-font-size: 24px;"/>
        <Label text="Let's get Started" style="-fx-text-fill: white;"/>
        <TextField promptText="Name"/>
        <TextField promptText="Email"/>
        <TextField promptText="Phone"/>
        <PasswordField promptText="Password"/>
        <CheckBox text="I Accept terms and conditions" style="-fx-text-fill: white;"/>
        <Button text="Register" style="-fx-pref-width: 200; -fx-background-color: white; -fx-text-fill: #ff8c00;"/>
        <HBox alignment="CENTER" spacing="10">
            <Button text="Facebook" style="-fx-background-color: #3b5998; -fx-text-fill: white;"/>
            <Button text="Twitter" style="-fx-background-color: #1da1f2; -fx-text-fill: white;"/>
        </HBox>
    </VBox>
</HBox>