<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="600.0" prefWidth="420.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml">

    <style>
        -fx-background-color: linear-gradient(to bottom right,#1d3557,#2f3e46,#5b4636);
    </style>

    <children>

        <!-- Información del usuario -->

        <VBox alignment="CENTER"
              layoutX="110"
              layoutY="55"
              prefWidth="200"
              spacing="8">

            <Circle radius="45" fill="#d9d9d9" stroke="white" strokeWidth="2"/>

            <Label text="Username"
                   style="-fx-font-size:24px;
                          -fx-font-weight:bold;
                          -fx-text-fill:white;"/>

            <Label text="mobile"
                   style="-fx-font-size:14px;
                          -fx-text-fill:#d0d0d0;"/>

        </VBox>

        <!-- Espaciador -->

        <Region layoutY="220"
                prefHeight="140"
                prefWidth="420"/>

        <!-- Opciones -->

        <HBox alignment="CENTER"
              layoutY="330"
              prefWidth="420"
              spacing="110">

            <VBox alignment="CENTER" spacing="8">

                <Button text="⏰"
                        prefHeight="45"
                        prefWidth="45"
                        style="-fx-background-radius:50;
                               -fx-background-color:white;
                               -fx-font-size:18;"/>

                <Label text="Remind me"
                       style="-fx-text-fill:white;
                              -fx-font-size:12px;"/>

            </VBox>

            <VBox alignment="CENTER" spacing="8">

                <Button text="💬"
                        prefHeight="45"
                        prefWidth="45"
                        style="-fx-background-radius:50;
                               -fx-background-color:white;
                               -fx-font-size:18;"/>

                <Label text="Message"
                       style="-fx-text-fill:white;
                              -fx-font-size:12px;"/>

            </VBox>

        </HBox>

        <!-- Botones inferiores -->

        <HBox alignment="CENTER"
              layoutY="455"
              prefWidth="420"
              spacing="90">

            <VBox alignment="CENTER" spacing="8">

                <Button text="📞"
                        prefHeight="65"
                        prefWidth="65"
                        style="-fx-background-radius:50;
                               -fx-background-color:#e53935;
                               -fx-text-fill:white;
                               -fx-font-size:22;"/>

                <Label text="Decline"
                       style="-fx-text-fill:white;"/>

            </VBox>

            <VBox alignment="CENTER" spacing="8">

                <Button text="📞"
                        prefHeight="65"
                        prefWidth="65"
                        style="-fx-background-radius:50;
                               -fx-background-color:#37c84b;
                               -fx-text-fill:white;
                               -fx-font-size:22;"/>

                <Label text="Accept"
                       style="-fx-text-fill:white;"/>

            </VBox>

        </HBox>

    </children>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

</AnchorPane>